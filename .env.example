# Supabase browser values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only. Never expose in browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SENSITIVE_HASH_SECRET=change-this-long-random-string

# Optional external API keys. If empty, deterministic mock adapters are used.
NTS_SERVICE_KEY=
KAKAO_REST_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_PLACES_API_KEY=

# App URL. On Vercel this can be omitted if VERCEL_URL exists.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron protection
CRON_SECRET=change-this-cron-secret

# Import tuning
IMPORT_BATCH_SIZE=500

# Set true only when you want frontend mock fallback during UI design.
NEXT_PUBLIC_USE_MOCK_FALLBACK=false
NEXT_PUBLIC_DEMO_CUSTOMER_ID=
